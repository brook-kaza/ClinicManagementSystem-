# --- PostgreSQL Global Credentials ---
POSTGRES_USER=clinic_admin
POSTGRES_PASSWORD=super_secure_password_123

# --- Clinic Backend Config ---
# The FastAPI app relies on a full DATABASE_URL connection string:
DATABASE_URL=postgresql://clinic_admin:super_secure_password_123@db:5432/clinic_db
ENVIRONMENT=development
ALLOWED_ORIGINS=http://46.225.86.61,https://46.225.86.61,http://localhost,http://127.0.0.1

# --- N8N Database Config ---
# N8N connects via individual variables rather than a single string:
DB_POSTGRESDB_DATABASE=n8n_db
DB_POSTGRESDB_HOST=db
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_USER=clinic_admin
DB_POSTGRESDB_PASSWORD=super_secure_password_123
